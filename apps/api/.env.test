# Test environment variables
# Used by Jest test setup (test/setup.ts)
NODE_ENV=test

# JWT (test secret - not used for real auth in mocked tests)
JWT_SECRET=test-jwt-secret-at-least-32-characters-long
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# Database (not used in mocked tests, but prevents startup errors)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shellkeep_test
POSTGRES_SSL=false

# OAuth (mocked in tests)
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Admin bootstrap
INITIAL_ADMIN_EMAIL=admin@test.example.com

# Encryption (32-byte base64 key for tests)
ENCRYPTION_KEY=dGVzdC1lbmNyeXB0aW9uLWtleS0zMi1ieXRlcw==

# Storage (not used in mocked tests)
STORAGE_PROVIDER=s3
S3_BUCKET=test-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=test-key-id
AWS_SECRET_ACCESS_KEY=test-secret-key

# Observability (disabled in tests)
OTEL_ENABLED=false
